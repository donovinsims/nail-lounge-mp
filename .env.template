# =============================================================================
# Nail Salon Template — Required Environment Variables
# Copy this file to .env and fill in your salon's values.
# =============================================================================

# --- Supabase (required for ALL deployments) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --- Salon Identity (set this BEFORE first deploy) ---
# The UUID of your salon row in the `salons` table.
# Each deployment = one salon. This is how the app knows WHICH salon to serve.
VITE_SALON_ID=

# --- Salon Branding (shown in header, footer, meta tags, SEO) ---
VITE_SALON_NAME=Your Salon Name
VITE_SALON_ADDRESS=
VITE_SALON_PHONE=
VITE_SALON_TAGLINE=Precision nail care

# --- Open Graph / SEO ---
# URL to a branded OG image (1200×630 recommended) for social shares + JSON-LD.
# Leave empty to hide the og:image tags (or use the fallback behavior).
VITE_OG_IMAGE=

# --- Salon Social & Contact (optional — shown in footer, gallery, etc.) ---
# If not set, social links will not appear in the UI.
VITE_SALON_EMAIL=
VITE_SALON_MAPS_URL=
VITE_SALON_MAP_EMBED=
VITE_SALON_INSTAGRAM=
VITE_SALON_FACEBOOK=
VITE_SALON_TIKTOK=
VITE_SALON_BOOKSY=
VITE_SALON_YELP=

# --- Feature Flags ---
# Enables the manual "Seed Demo Data" button in admin dashboard.
# NOT required for auto-seed (first-run detection is built-in and independent).
VITE_ALLOW_SEED_DATA=false

# --- Application URL (used for Stripe return URLs, Twilio webhooks) ---
# Server also reads APP_URL (no VITE_ prefix) as a fallback for server-to-server webhook calls.
VITE_APP_URL=https://your-salon-domain.com

# --- Stripe (online payments) ---
# VITE_ prefixed = public (publishable key). No prefix = server-only (secret key, webhook secret).
# Omit the server-only keys to disable Stripe payments (deposit collection skipped).
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Twilio (SMS confirmations + AI receptionist) ---
# Omit to disable SMS (booking flow won't send texts).
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
VITE_TWILIO_PHONE_NUMBER=+1XXXYYYZZZZ

# --- Umami Analytics (website visitor tracking) ---
# Sign up at https://umami.is (free tier: 100k events/month).
# Get your website ID from Umami Cloud → Settings → Websites.
# Omit to disable analytics entirely.
VITE_UMAMI_WEBSITE_ID=
# Override for self-hosted Umami. Defaults to Umami Cloud CDN.
# VITE_UMAMI_HOST=https://cloud.umami.is

# --- Resend (email notifications) ---
# Omit to disable email confirmations for bookings.
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
# Optional: override the "from" email (must be verified in Resend).
# Defaults to "onboarding@resend.dev" (Resend's sandbox — sends only to your verified address).
RESEND_FROM_EMAIL=
