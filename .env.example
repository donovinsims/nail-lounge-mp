# =============================================================================
# Nail Lounge — Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# For Vercel deployment, set these in the Vercel dashboard.
#
# VITE_* vars are public (embedded in client bundle).
# Non-VITE_* vars are server-only (not sent to client).
# =============================================================================

# ── Supabase (public, available to client & server) ─────────────────────────
VITE_SUPABASE_URL="https://<your-project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# ── Supabase (server-only, required at runtime) ─────────────────────────────
SUPABASE_URL="https://<your-project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# ── Supabase (server-only, for admin operations that bypass RLS) ────────────
# ⚠️  Keep this secret. Do NOT commit to git or expose to the client.
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"

# ── Supabase (reference only, not read by code) ─────────────────────────────
# SUPABASE_PROJECT_ID="<your-project-id>"
# VITE_SUPABASE_PROJECT_ID="<your-project-id>"

# ── Salon Identity (VITE_* = public, embedded in client bundle) ─────────────
# These white-label the application for a specific salon deployment.
VITE_SALON_ID="11111111-1111-1111-1111-111111111111"
VITE_SALON_NAME="Nail Lounge"
VITE_SALON_PHONE="+1 815-977-3443"
VITE_SALON_ADDRESS="1513 West Lane Rd, Machesney Park, IL 61115, United States"
VITE_SALON_TAGLINE="Precision nail care"
VITE_SALON_MAPS_URL="https://share.google/qo03O2XzAhE7hTXjL"
VITE_SALON_MAP_EMBED="https://maps.google.com/maps?q=1513+West+Lane+Rd,+Machesney+Park,+IL+61115&output=embed"
VITE_SALON_INSTAGRAM="https://www.instagram.com/nailloungemachesneypark"
VITE_SALON_FACEBOOK="https://www.facebook.com/nailloungemachesneypark"
VITE_SALON_TIKTOK="https://www.tiktok.com/@nailloungemp"
VITE_SALON_YELP="https://www.yelp.com/biz/nail-lounge-machesney-park"

# ── Application URLs ────────────────────────────────────────────────────────
APP_URL="https://nails815.vercel.app"
VITE_APP_URL="https://nails815.vercel.app"

# ── Twilio (SMS confirmations + rating loop, server-only) ───────────────────
TWILIO_ACCOUNT_SID="<your-twilio-account-sid>"
TWILIO_AUTH_TOKEN="<your-twilio-auth-token>"
TWILIO_PHONE_NUMBER="<your-twilio-phone-number>"
GOOGLE_REVIEW_URL="<optional-google-review-link>"

# ── Resend (email confirmations, server-only) ───────────────────────────────
RESEND_API_KEY="<your-resend-api-key>"

# ── Analytics (optional) ────────────────────────────────────────────────────
VITE_UMAMI_WEBSITE_ID=""
VITE_UMAMI_HOST=""
